{
  "name": "cashfolio-app2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "prisma:generate": "DATABASE_URL=dummy prisma generate",
    "e2e:install": "playwright install chromium",
    "e2e": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5433/postgres?schema=public} BASE_URL=${BASE_URL:-http://127.0.0.1:4173} E2E_AUTH_BYPASS=${E2E_AUTH_BYPASS:-true} E2E_AUTH_EXTERNAL_ID=${E2E_AUTH_EXTERNAL_ID:-e2e-user} pnpm exec prisma migrate deploy && playwright test",
    "e2e:ci": "playwright test"
  },
  "dependencies": {
    "@logto/node": "^3.1.8",
    "@mantine/core": "^8.3.12",
    "@mantine/dates": "^8.3.13",
    "@mantine/form": "^8.3.14",
    "@mantine/hooks": "^8.3.12",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-router": "^1.121.34",
    "@tanstack/react-start": "^1.121.34",
    "ag-grid-enterprise": "^35.0.1",
    "ag-grid-react": "^35.0.1",
    "date-fns": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-number-format": "^5.4.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prisma": "^7.2.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
